# Hubu Agent Backend 环境配置示例
# 复制此文件为 .env 并填入实际值

# 应用基础配置
APP_NAME=Hubu Agent
APP_VERSION=0.1.0
DEBUG=False
HOST=0.0.0.0
PORT=8000

# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=hubu_agent

# Redis配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=2
REDIS_PASSWORD=your_redis_password

# LLM配置（已迁移至数据库 llm_provider 表，通过前端 供应商管理 页面配置）

# Embedding配置（已迁移至数据库 embedding_provider 表，通过前端 Embedding管理 页面配置）

# Milvus配置
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_USER=root
MILVUS_PASSWORD=your_milvus_password
EMBEDDING_DIMENSION=1024

# 工具配置
TAVILY_API_KEY=your_tavily_api_key  # Tavily网络搜索API Key
WEATHER_API_KEY=your_weather_api_key  # 高德地图天气API Key
WEATHER_API_ENDPOINT=https://restapi.amap.com/v3/weather/weatherInfo  # 高德天气API端点

# 完整代码执行器配置（code_exec）子进程执行，无模块限制
CODE_EXEC_MAX_OUTPUT=10000  # 最大输出字符数

# 文件管理器配置（file_manager）
FILE_MAX_SIZE=52428800  # 单文件最大字节数（默认50MB）

# 包安装器配置（package_installer）
PKG_ALLOW_PIP=true  # 是否允许 pip install
PKG_ALLOW_NPM=true  # 是否允许 npm install
PKG_PIP_TIMEOUT=120  # pip 安装超时（秒）
PKG_NPM_TIMEOUT=120  # npm 安装超时（秒）
PKG_ALLOW_LIST=  # 允许安装的包名（逗号分隔，留空不限制）
PKG_DENY_LIST=  # 禁止安装的包名（逗号分隔）

# 日志配置
LOG_LEVEL=INFO
LOG_FILE_LEVEL=WARNING

