# Hubu Agent Backend 环境配置模板
# 复制此文件为 .env 并填写实际配置

# 应用基础配置
APP_NAME=Hubu Agent
APP_VERSION=0.1.0
DEBUG=False
HOST=0.0.0.0
PORT=8000

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=hubu_agent

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# LLM配置
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-3.5-turbo

# Embedding配置
EMBEDDING_API_KEY=your_api_key_here
EMBEDDING_MODEL=text-embedding-v3

# Milvus配置
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=root
MILVUS_PASSWORD=Milvus
EMBEDDING_DIMENSION=1024

# 工具配置
TAVILY_API_KEY=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  # Tavily网络搜索API Key
WEATHER_API_KEY=your_amap_api_key_here  # 高德地图天气API Key

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
