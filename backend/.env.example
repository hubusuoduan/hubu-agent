# Hubu Agent Backend 环境配置模板
# 复制此文件为 .env 并填写实际配置

# 应用基础配置
APP_NAME=Hubu Agent
APP_VERSION=0.1.0
DEBUG=False
HOST=0.0.0.0
PORT=8000

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=hubu_agent

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# LLM配置
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-3.5-turbo

# 对话历史管理配置
MAX_HISTORY_ROUNDS=10  # 最大保留对话轮数
ENABLE_HISTORY_SUMMARY=True  # 是否启用历史摘要
SUMMARY_THRESHOLD=20  # 触发摘要的消息条数阈值

# 上下文长度控制配置
MAX_CONTEXT_TOKENS=8000  # 最大上下文token数
RESERVE_FOR_RESPONSE=2000  # 预留响应token数
ENABLE_TOKEN_CONTROL=True  # 是否启用token控制

# Embedding配置
EMBEDDING_API_KEY=your_api_key_here
EMBEDDING_MODEL=text-embedding-v3

# Milvus配置
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=root
MILVUS_PASSWORD=Milvus
EMBEDDING_DIMENSION=1024
MILVUS_NPROBE=32  # 向量检索时搜索的聚类中心数量

# RAG检索配置
RAG_TOP_K=8  # 每个知识库检索的文档数量
RAG_MIN_SCORE=0.2  # 最小分数阈值
RAG_RERANKER_TOP_N=15  # 参与重排序的文档数量
RAG_HYBRID_WEIGHTS=0.4,0.6  # BM25权重,语义权重(逗号分隔)

# 长期记忆配置
MEMORY_TOP_K=5  # 记忆检索返回的最大数量
MEMORY_MIN_SCORE=0.3  # 记忆检索最低相似度阈值

# Agent配置
AGENT_MAX_ITERATIONS=10  # Agent最大工具调用轮数，防止死循环

# 工具配置
TAVILY_API_KEY=tvly-dev-xxx  # Tavily网络搜索API Key
WEATHER_API_KEY=your_amap_api_key_here  # 高德地图天气API Key
WEATHER_API_ENDPOINT=https://restapi.amap.com/v3/weather/weatherInfo  # 高德天气API端点

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
