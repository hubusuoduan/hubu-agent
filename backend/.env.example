# Hubu Agent Backend 环境配置示例
# 复制此文件为 .env 并填入实际值

# 应用基础配置
APP_NAME=Hubu Agent
APP_VERSION=0.1.0
DEBUG=False
HOST=0.0.0.0
PORT=8000

# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=hubu_agent

# Redis配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=2
REDIS_PASSWORD=your_redis_password

# LLM配置
LLM_API_KEY=your_llm_api_key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3-vl-32b-thinking
LLM_STREAM_CHUNK_TIMEOUT=300  # 流式chunk超时（秒），thinking模型需调大，设0禁用

# 多模型Provider配置（JSON数组，每个元素是一个模型Provider）
# id: 唯一标识, name: 显示名称, api_key/base_url/model: 模型配置, is_default: 是否默认
# 示例：配置多个模型
# LLM_PROVIDERS=[{"id":"qwen3-vl-32b","name":"Qwen3-VL-32B","api_key":"your_llm_api_key","base_url":"https://dashscope.aliyuncs.com/compatible-mode/v1","model":"qwen3-vl-32b-thinking","is_default":true},{"id":"qwen-vl-plus","name":"Qwen-VL-Plus","api_key":"your_llm_api_key","base_url":"https://dashscope.aliyuncs.com/compatible-mode/v1","model":"qwen-vl-plus-latest"}]
LLM_PROVIDERS=[]

# 对话历史管理配置
MAX_HISTORY_ROUNDS=10  # 最大保留对话轮数
ENABLE_HISTORY_SUMMARY=True  # 是否启用历史摘要
SUMMARY_THRESHOLD=20  # 触发摘要的消息条数阈值

# 上下文长度控制配置
MAX_CONTEXT_TOKENS=8000  # 最大上下文token数
RESERVE_FOR_RESPONSE=2000  # 预留响应token数
ENABLE_TOKEN_CONTROL=True  # 是否启用token控制

# Embedding配置
EMBEDDING_API_KEY=your_embedding_api_key
EMBEDDING_MODEL=text-embedding-v3

# Milvus配置
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_USER=root
MILVUS_PASSWORD=your_milvus_password
EMBEDDING_DIMENSION=1024
MILVUS_NPROBE=16  # 向量检索时搜索的聚类中心数量

# RAG检索配置
RAG_TOP_K=8  # 每个知识库检索的文档数量
RAG_MIN_SCORE=0.2  # 最小分数阈值
RAG_RERANKER_TOP_N=15  # 参与重排序的文档数量
RAG_HYBRID_WEIGHTS=0.4,0.6  # BM25权重,语义权重(逗号分隔)

# 长期记忆配置
MEMORY_TOP_K=5  # 记忆检索返回的最大数量
MEMORY_MIN_SCORE=0.3  # 记忆检索最低相似度阈值

# Agent配置
AGENT_MAX_ITERATIONS=10  # Agent最大工具调用轮数，防止死循环

# 工具配置
TAVILY_API_KEY=your_tavily_api_key  # Tavily网络搜索API Key
WEATHER_API_KEY=your_weather_api_key  # 高德地图天气API Key
WEATHER_API_ENDPOINT=https://restapi.amap.com/v3/weather/weatherInfo  # 高德天气API端点

# 沙箱代码执行器配置（code_runner）进程内exec()，安全受限
SANDBOX_TIMEOUT=30  # 默认超时（秒）
SANDBOX_MAX_TIMEOUT=120  # 最大超时（秒）
SANDBOX_MAX_OUTPUT=5000  # 最大输出字符数

# 完整代码执行器配置（code_exec）子进程执行，无模块限制
CODE_EXEC_TIMEOUT=60  # 默认超时（秒）
CODE_EXEC_MAX_TIMEOUT=300  # 最大超时（秒）
CODE_EXEC_MAX_OUTPUT=10000  # 最大输出字符数

# 文件管理器配置（file_manager）Skill产出文件的存放位置
FILE_WORKSPACE=output  # 工作目录（相对于backend目录的相对路径）
FILE_MAX_SIZE=52428800  # 单文件最大字节数（默认50MB）
FILE_ALLOW_EXTENSIONS=  # 允许的文件扩展名（逗号分隔，留空不限制）
FILE_DENY_EXTENSIONS=.exe,.bat,.cmd,.ps1,.sh,.dll,.so  # 禁止的文件扩展名（逗号分隔）

# 包安装器配置（package_installer）
PKG_ALLOW_PIP=true  # 是否允许 pip install
PKG_ALLOW_NPM=true  # 是否允许 npm install
PKG_PIP_TIMEOUT=120  # pip 安装超时（秒）
PKG_NPM_TIMEOUT=120  # npm 安装超时（秒）
PKG_ALLOW_LIST=  # 允许安装的包名（逗号分隔，留空不限制）
PKG_DENY_LIST=  # 禁止安装的包名（逗号分隔）

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
